# ---- Data (raw + processed) : too big / regenerated by scripts ----
data/raw/*
data/processed/*
!data/**/.gitkeep

# ---- Model artifacts ----
# Ignore everything in models/ EXCEPT the three small serving artifacts that the
# deployed app / Docker image need to load (the model, its tuned threshold, and
# the input schema). Committing these makes the app deployable without retraining.
models/*
!models/.gitkeep
!models/model.joblib
!models/threshold.json
!models/feature_schema.json

# ---- MLflow experiment-tracking store ----
mlruns/
mlartifacts/
mlflow.db

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ---- OS / editor ----
.DS_Store
*.swp
.vscode/

# ---- Stray screenshots (only intentionally-named images are committed) ----
Screenshot*.png
